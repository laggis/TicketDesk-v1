# ─── TicketDesk — Single Config File ──────────────────────────────────────────

# Discord Bot
BOT_TOKEN=<YOUR_BOT_TOKEN>
GUILD_ID=<YOUR_GUILD_ID>

# Channels
TICKET_CHANNEL_ID=<TICKET_CHANNEL_ID>
TRANSCRIPT_CHANNEL_ID=<TRANSCRIPT_CHANNEL_ID>
MOD_LOG_CHANNEL_ID=<MOD_LOG_CHANNEL_ID>

# Staff roles (comma separated)
SUPPORT_ROLE_ID=<SUPPORT_ROLE_ID_1>,<SUPPORT_ROLE_ID_2>

# Admin roles — members with these roles are automatically added to /note threads
# Add your admin Discord role IDs here (comma separated)
ADMIN_ROLE_IDS=<ADMIN_ROLE_ID_1>,<ADMIN_ROLE_ID_2>

# Discord category IDs (fallback — can be managed from panel instead)
SUPPORT_CATEGORY_ID=<SUPPORT_CATEGORY_ID>
KOP_CATEGORY_ID=<KOP_CATEGORY_ID>
OVRIGT_CATEGORY_ID=<OVRIGT_CATEGORY_ID>
PANEL_CATEGORY_ID=<PANEL_CATEGORY_ID>

# How long before ticket channel is deleted after closing (ms)
TICKET_DELETE_DELAY_MS=5000

# Database
DB_HOST=<DATABASE_HOST>
DB_USER=<DATABASE_USER>
DB_PASSWORD=<DATABASE_PASSWORD>
DB_NAME=<DATABASE_NAME>
DB_PORT=3306

# API
TICKETDESK_PORT=52007
TICKETDESK_HOST=<API_HOST>
PANEL_ORIGIN=<PANEL_ORIGIN>
JWT_SECRET=<JWT_SECRET>
JWT_SECRETS=<JWT_SECRETS>
JWT_EXPIRES_IN=30d
SETUP_SECRET=<SETUP_SECRET>

# Stale ticket reminder defaults — managed via the panel Settings page
# (stored in bot_settings.json, editable from the admin panel under Settings)
# These are the fallback values used if bot_settings.json does not exist yet:
#   staleRemindersEnabled = true
#   staleTicketMinutes    = 30    (minutes before first ping)
#   staleReminderCooldown = 30    (minutes between repeated pings)

# Server branding
SERVER_NAME=TicketDesk

# AI (optional — remove to disable)
GROQ_API_KEY=<GROQ_API_KEY>
