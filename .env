# ─── TicketDesk — Single Config File ──────────────────────────────────────────

# Discord Bot
BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
GUILD_ID=YOUR_GUILD_ID

# Channels
TICKET_CHANNEL_ID=YOUR_TICKET_PANEL_CHANNEL_ID
TRANSCRIPT_CHANNEL_ID=YOUR_TRANSCRIPT_CHANNEL_ID
MOD_LOG_CHANNEL_ID=

# Staff roles (comma separated)
SUPPORT_ROLE_IDS=ROLE_ID_1,ROLE_ID_2

# Discord category IDs (fallback — can be managed from panel instead)
SUPPORT_CATEGORY_ID=
KOP_CATEGORY_ID=
OVRIGT_CATEGORY_ID=
PANEL_CATEGORY_ID=

# How long before ticket channel is deleted after closing (ms)
TICKET_DELETE_DELAY_MS=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=ticketdesk
DB_PASSWORD=CHANGE_ME
DB_NAME=ticketdesk

# API
TICKETDESK_PORT=52007
TICKETDESK_HOST=0.0.0.0
PANEL_ORIGIN=
JWT_SECRET=CHANGE_THIS_TO_SOMETHING_RANDOM_AND_LONG
JWT_SECRETS=
JWT_EXPIRES_IN=30d
SETUP_SECRET=CHANGE_THIS_TOO

# Server branding
SERVER_NAME=TicketDesk

# AI (optional — remove to disable)
GROQ_API_KEY=
