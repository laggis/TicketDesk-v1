# ─── TicketDesk — Single Config File ──────────────────────────────────────────

# Discord Bot
BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
GUILD_ID=YOUR_GUILD_ID

# Channels
TICKET_CHANNEL_ID=YOUR_TICKET_CHANNEL_ID
TRANSCRIPT_CHANNEL_ID=YOUR_TRANSCRIPT_CHANNEL_ID
MOD_LOG_CHANNEL_ID=YOUR_MOD_LOG_CHANNEL_ID

# Staff roles (comma separated)
SUPPORT_ROLE_ID=ROLE_ID_1,ROLE_ID_2

# Discord category IDs
SUPPORT_CATEGORY_ID=YOUR_SUPPORT_CATEGORY_ID
KOP_CATEGORY_ID=YOUR_KOP_CATEGORY_ID
OVRIGT_CATEGORY_ID=YOUR_OVRIGT_CATEGORY_ID
PANEL_CATEGORY_ID=YOUR_PANEL_CATEGORY_ID

# How long before ticket channel is deleted after closing (ms)
TICKET_DELETE_DELAY_MS=5000

# Database
DB_HOST=localhost
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=YOUR_DB_NAME
DB_PORT=3306

# API
TICKETDESK_PORT=52007
TICKETDESK_HOST=0.0.0.0
PANEL_ORIGIN=
JWT_SECRET=YOUR_JWT_SECRET
JWT_SECRETS=YOUR_JWT_SECRETS
JWT_EXPIRES_IN=30d
SETUP_SECRET=YOUR_SETUP_SECRET

# Server branding
SERVER_NAME=TicketDesk

# AI (optional — remove to disable)
GROQ_API_KEY=YOUR_GROQ_API_KEY